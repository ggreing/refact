# API Settings
APP_NAME=NSP Chat API
VERSION=1.0.0
DEBUG=true
HOST=0.0.0.0
PORT=8000
ENVIRONMENT=development
LOG_LEVEL=INFO

# RabbitMQ Settings
RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=guest
RABBITMQ_VHOST=/

# MongoDB Settings
MONGODB_URL=mongodb://mongo:27017
MONGODB_DATABASE=nsp_chat

# MinIO Settings
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_SECURE=false
MINIO_BUCKET=chat-files

# Qdrant Settings
QDRANT_HOST=qdrant
QDRANT_PORT=6333
QDRANT_COLLECTION=chat_vectors

# MongoDB Express Settings
MONGO_EXPRESS_USERNAME=admin
MONGO_EXPRESS_PASSWORD=pass
MONGO_EXPRESS_PORT=8081
MONGO_EXPRESS_USERNAME=admin
MONGO_EXPRESS_PASSWORD=pass