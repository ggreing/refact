{
  "apps": [
    {
      "name": "ai-assist-worker",
      "script": "/app/worker/ai/ai_assist/ai_run.py",
      "interpreter": "python3",
      "instances": 3,
      "exec_mode": "fork",
      "env": {
        "PYTHONPATH": "/app",
        "WORKER_TYPE": "ai_assist"
      },
      "error_file": "/app/logs/ai-assist-error.log",
      "out_file": "/app/logs/ai-assist-out.log",
      "log_file": "/app/logs/ai-assist-combined.log",
      "time": true,
      "autorestart": true,
      "max_restarts": 10,
      "min_uptime": "10s",
      "max_memory_restart": "500M",
      "restart_delay": 4000,
      "kill_timeout": 5000,
      "listen_timeout": 10000
    }
  ]
}